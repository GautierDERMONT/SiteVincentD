# Activer le moteur de réécriture
RewriteEngine On

# Forcer HTTPS (décommentez quand vous aurez un certificat SSL)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Rediriger www vers non-www (ou l'inverse)
# Version : sans www vers www
# RewriteCond %{HTTP_HOST} ^pleiades-partners\.fr [NC]
# RewriteRule ^(.*)$ https://www.pleiades-partners.fr/$1 [R=301,L]

# Version : www vers sans www (décommentez celle-ci et commentez l'autre)
RewriteCond %{HTTP_HOST} ^www\.pleiades-partners\.fr [NC]
RewriteRule ^(.*)$ https://pleiades-partners.fr/$1 [R=301,L]

# Supprimer l'extension .html des URLs
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# Rediriger les anciennes URLs avec .html vers la nouvelle version (SEO)
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Pages personnalisées d'erreur
ErrorDocument 404 /404
ErrorDocument 403 /403

# Compression GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache navigateur
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>