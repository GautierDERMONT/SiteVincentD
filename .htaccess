RewriteEngine On

# Rediriger www vers non-www
RewriteCond %{HTTP_HOST} ^www\.pleiades-partners\.fr [NC]
RewriteRule ^(.*)$ https://pleiades-partners.fr/$1 [R=301,L]

# ===== REDIRECTIONS PRIORITAIRES =====

# 1. Rediriger index.html VERS la racine /
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html
RewriteRule ^index\.html$ / [R=301,L]

# 2. Rediriger /index (sans .html) VERS la racine /
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index
RewriteRule ^index$ / [R=301,L]

# 3. Rediriger HTTP vers HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://pleiades-partners.fr/$1 [R=301,L]

# ===== RÉÉCRITURE INTERNE =====

# 4. Si on demande /, servir index.html en interne
RewriteRule ^$ index.html [L]

# 5. Supprimer l'extension .html en interne
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]

# 6. Rediriger les URLs avec .html vers sans extension
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ===== PAGES D'ERREUR =====

ErrorDocument 404 /404
ErrorDocument 403 /403

# ===== COMPRESSION =====

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ===== CACHE =====

<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images (cache 1 an - OK car elles changent rarement)
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # CSS et JS : PAS DE CACHE (modifications visibles immédiatement)
    ExpiresByType text/css "access plus 0 seconds"
    ExpiresByType application/javascript "access plus 0 seconds"
    
    # HTML : PAS DE CACHE
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>